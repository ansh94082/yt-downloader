{
  "name": "yt-downloader",
  "productName": "YT Downloader",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "desktopName": "yt-downloader",
  "main": "electron/main.js",
  "scripts": {
    "vite": "vite",
    "electron": "wait-on http://localhost:6767 && electron .",
    "start": "npm run dev",
    "dev": "concurrently \"npm run vite\" \"npm run electron\"",
    "lint": "eslint .",
    "test": "vite && electron .",
    "preview": "vite preview",

    "build": "npm run build:renderer",
    "build:renderer": "vite build",

    "dist:linux": "npm run build && electron-builder --config electron-builder-linux.yml",
    "dist:win": "npm run build && electron-builder --config electron-builder-win.yml",
    "dist:mac": "npm run build && electron-builder --config electron-builder-mac.yml"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "child_process": "^1.0.2",
    "electron-store": "^11.0.2",
    "lucide-react": "^1.21.0",
    "os": "^0.1.2",
    "queue": "^7.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.17.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}